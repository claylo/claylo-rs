name: Deploy documentation site

on:
  push:
    branches: [main]
    paths:
      - "docs/**"
      - "site/**"
  workflow_dispatch:
{% if site_deploy_github_pages %}

permissions:
  contents: read
  pages: write
  id-token: write

concurrency:
  group: pages
  cancel-in-progress: false
{% else %}

permissions:
  contents: read
  deployments: write

concurrency:
  group: deploy-site
  cancel-in-progress: false
{% endif %}

jobs:
  build:
    runs-on: ubuntu-latest
    timeout-minutes: 15
    steps:
      - name: Checkout
        uses: actions/checkout@de0fac2e4500dabe0009e67214ff5f5447ce83dd # v6.0.2
{% if site_deploy_github_pages %}

      - name: Configure Pages
        uses: actions/configure-pages@45bfe0192ca1faeb007ade9deae92b16b8254a0d # v6.0.0
{% endif %}

      - name: Setup site dependencies
        uses: ./.github/actions/setup-site-deps

      - name: Build site
        run: {{ npm }} run build
        working-directory: site
{% if site_deploy_github_pages %}

      - name: Upload Pages artifact
        uses: actions/upload-pages-artifact@7b1f4a764d45c48632c6b24a0339c27f5614fb0b # v4.0.0
        with:
          path: site/dist
{% endif %}
{% if site_deploy_github_pages %}

  deploy:
    needs: build
    runs-on: ubuntu-latest
    timeout-minutes: 10
    environment:
      name: github-pages
      url: {% raw %}${{ steps.deployment.outputs.page_url }}{% endraw %}
    steps:
      - name: Deploy to GitHub Pages
        id: deployment
        uses: actions/deploy-pages@cd2ce8fcbc39b97be8ca5fce6e763baed58fa128 # v5.0.0
{% else %}

  deploy:
    needs: build
    runs-on: ubuntu-latest
    timeout-minutes: 15
    steps:
      - name: Checkout
        uses: actions/checkout@de0fac2e4500dabe0009e67214ff5f5447ce83dd # v6.0.2

      - name: Setup site dependencies
        uses: ./.github/actions/setup-site-deps

      - name: Build site
        run: {{ npm }} run build
        working-directory: site

      - name: Deploy to Cloudflare Pages
        uses: cloudflare/wrangler-action@da0e0dfe58b7a431659754fdf3f186c529afbe65 # v3.14.1
        with:
          apiToken: {% raw %}${{ secrets.CLOUDFLARE_API_TOKEN }}{% endraw %}
          accountId: {% raw %}${{ secrets.CLOUDFLARE_ACCOUNT_ID }}{% endraw %}
          command: pages deploy site/dist --project-name={{ project_name }}-docs
{% endif %}
