{%- if has_cli -%}
[workspace]
members = [{% if has_xtask %}"xtask", {% endif %}"crates/*"]
default-members = ["crates/*"]
resolver = "{{ 3 if edition | int >= 2024 else 2 }}"

[workspace.package]
edition = "{{ edition }}"
license = "{% if license | length > 1 %}{{ license | join(' OR ') }}{% else %}{{ license | first }}{% endif %}"
version = "0.1.0"
# version we want to allow
rust-version = "{{ msrv }}"
readme = "README.md"
repository = "https://github.com/{{ owner }}/{{ project_name }}"
homepage = "https://github.com/{{ owner }}/{{ project_name }}"
documentation = "https://docs.rs/{{ project_name }}"
description = "{{ project_description }}"
keywords = []
categories = [{% for cat in categories %}"{{ cat.split(': ')[1] }}"{% if not loop.last %}, {% endif %}{% endfor %}]

[workspace.lints.rust]
# Use "deny" instead of "forbid" to allow benchmark harnesses to override
# when their instrumentation machinery requires it (e.g., gungraun's FFI exports)
unsafe_code = "deny"
# Encourage documentation - warn on public items missing docs
missing_docs = "warn"

{%- if lint_level != 'relaxed' %}
[workspace.lints.clippy]
all = "warn"
{%- if lint_level == 'strict' %}
nursery = "warn"
{%- endif %}
{%- endif %}
{%- else -%}
[package]
name = "{{ project_name }}"
version = "0.1.0"
edition = "{{ edition }}"
rust-version = "{{ msrv }}"
license = "{% if license | length > 1 %}{{ license | join(' OR ') }}{% else %}{{ license | first }}{% endif %}"
readme = "README.md"
repository = "https://github.com/{{ owner }}/{{ project_name }}"
homepage = "https://github.com/{{ owner }}/{{ project_name }}"
documentation = "https://docs.rs/{{ project_name }}"
description = "{{ project_description }}"
keywords = []
categories = [{% for cat in categories %}"{{ cat.split(': ')[1] }}"{% if not loop.last %}, {% endif %}{% endfor %}]
exclude = [
    "/.claude/",
    "/.github/",
    "/AGENTS.md",
    "/.justfile",
    "/.editorconfig",
    "/.markdownlint.yaml",
    "/.yamllint",
    "/.envrc",
    "/.env",
    "/.env.rust",
{%- if has_benchmarks %}
    "/bench-reports/",
    "/scripts/",
{%- endif %}
    "/docs/",
    "/deny.toml",
    "/*.example",
]

[dependencies]
thiserror = "2.0"
tracing = "0.1"

[dev-dependencies]
{%- if has_benchmarks %}
divan = "0.1"
{%- endif %}

[lints.rust]
# Use "deny" instead of "forbid" to allow benchmark harnesses to override
# when their instrumentation machinery requires it
unsafe_code = "deny"
# Encourage documentation - warn on public items missing docs
missing_docs = "warn"
{% if lint_level != 'relaxed' %}

[lints.clippy]
all = "warn"
{%- if lint_level == 'strict' %}
nursery = "warn"
{%- endif %}
{%- endif %}
{%- if has_benchmarks %}

[[bench]]
name = "divan_benchmarks"
harness = false
{%- endif %}
{%- endif %}

# Optimize dependencies in dev mode for faster tests
# (keeps main crate unoptimized for fast incremental builds)
[profile.dev.package."*"]
debug = 0
opt-level = 1

[profile.dev.build-override]
debug = 0
opt-level = 1

# Reduce debug info size (line tables only, no variable info)
# Light optimization for better runtime without killing incremental builds
[profile.dev]
debug = "line-tables-only"
opt-level = 1
# On macOS, keep debug info from exploding into huge scattered dSYM trees
split-debuginfo = "packed"
codegen-units = 256

# Test profile with full debug symbols for profiling
[profile.test]
inherits = "dev"
codegen-units = 256
debug = true

# Release profile with reduced debug info
[profile.release]
debug = "line-tables-only"

# Debug-friendly profile for investigating mysteries (hangs, crashes, etc.)
# Usage: cargo build --profile mystery
[profile.mystery]
inherits = "release"
opt-level = 1
debug = true
strip = false
{% if has_benchmarks %}
# Optimized profile for benchmarks
[profile.bench]
inherits = "release"
lto = "thin"
debug = "line-tables-only"
{% endif %}
