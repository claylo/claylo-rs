[package]
name = "{{ project_name }}-core"
version.workspace = true
edition.workspace = true
rust-version.workspace = true
license.workspace = true
description = "Core library for {{ project_name }}"
repository.workspace = true
homepage.workspace = true
readme.workspace = true
exclude = [
    # Workspace-level files (/ = workspace root)
    "/.claude/",
    "/.github/",
    "/AGENTS.md",
    "/.justfile",
    "/.editorconfig",
    "/.markdownlint.yaml",
    "/.yamllint",
    "/.envrc",
    "/.env",
    "/.env.rust",
{% if has_benchmarks %}
    "/bench-reports/",
    "/scripts/",
{% endif %}
    "/docs/",
    "/deny.toml",
    # Example config files
    "/*.example",
]

[dependencies]
{% if has_config -%}
camino = { version = "1.2", features = ["serde1"] }
figment = { version = "0.10", features = ["toml", "yaml", "json"] }
serde = { version = "1.0", features = ["derive"] }
{% endif -%}
{% if has_config or has_jsonl_logging or has_opentelemetry -%}
directories = "6.0"
{% endif -%}
thiserror = "2.0"
tracing = "0.1"
{% if has_jsonl_logging or has_opentelemetry -%}
anyhow = "1.0"
serde_json = "1.0"
tracing-subscriber = { version = "0.3", features = ["env-filter"] }
tracing-appender = "0.2"
{% endif -%}
{% if has_opentelemetry -%}
opentelemetry = { version = "0.31", features = ["trace"] }
opentelemetry_sdk = { version = "0.31", features = ["trace", "rt-tokio"] }
opentelemetry-otlp = { version = "0.31", features = ["grpc-tonic", "http-json", "reqwest-blocking-client"] }
tracing-opentelemetry = "0.32"
{% endif -%}

[dev-dependencies]
{% if has_config -%}
tempfile = "3.27"
{% endif -%}
{% if has_benchmarks -%}
divan = "0.1"
{% endif -%}
{% if has_gungraun -%}
gungraun = "0.17"
{% endif %}
[lints]
workspace = true
{% if has_benchmarks %}
[[bench]]
name = "divan_benchmarks"
harness = false
{% endif %}
{% if has_gungraun %}
[[bench]]
name = "gungraun_benchmarks"
harness = false
{% endif %}
