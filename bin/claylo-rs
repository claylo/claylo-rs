#!/usr/bin/env bash
set -euo pipefail

# ---------------------------------------------------------------------------
# claylo-rs — friendly wrapper around copier for the claylo-rs template
# ---------------------------------------------------------------------------
# This script can run standalone (e.g., installed via brew) or from within
# the template repository. When standalone, it uses gh:claylo/claylo-rs.

# Require bash 4+ for associative arrays
if ((BASH_VERSINFO[0] < 4)); then
  echo "Error: bash 4+ required (you have ${BASH_VERSION})." >&2
  echo "On macOS: brew install bash" >&2
  exit 1
fi

# Version — "devel" in source, replaced by release process
VERSION="devel"

# Default template source (GitHub shorthand)
DEFAULT_TEMPLATE="gh:claylo/claylo-rs"

# ---------------------------------------------------------------------------
# Resolve symlinks to find the real script location
# ---------------------------------------------------------------------------
# ${BASH_SOURCE[0]} returns the symlink path if invoked via symlink.
# We need the actual script location to find template resources.
#
# Note: We can't use `readlink -f` here — that's GNU-only and doesn't exist
# on macOS's BSD readlink. This loop approach is portable across both.
resolve_script_path() {
  local source="${BASH_SOURCE[0]}"
  local dir

  # Follow symlink chain until we reach the actual file
  while [[ -L "$source" ]]; do
    dir="$(cd -P "$(dirname "$source")" && pwd)"
    source="$(readlink "$source")"
    # Handle relative symlinks (resolve them relative to symlink's directory)
    [[ "$source" != /* ]] && source="$dir/$source"
  done

  # Return the directory containing the resolved script
  cd -P "$(dirname "$source")" && pwd
}

SCRIPT_DIR="$(resolve_script_path)"
LOCAL_TEMPLATE="${SCRIPT_DIR}/.."

# Default filename for auto-discovered defaults
DEFAULTS_FILENAME=".claylo-rs.defaults.yaml"

# ---------------------------------------------------------------------------
# Find a defaults file by crawling upward from current directory
# ---------------------------------------------------------------------------
# Looks for .claylo-rs.defaults.yaml starting from cwd and walking up to /
find_defaults_file() {
  local dir="$PWD"

  while [[ "$dir" != "/" ]]; do
    if [[ -f "$dir/$DEFAULTS_FILENAME" ]]; then
      echo "$dir/$DEFAULTS_FILENAME"
      return 0
    fi
    dir="$(dirname "$dir")"
  done

  # Check root as well
  if [[ -f "/$DEFAULTS_FILENAME" ]]; then
    echo "/$DEFAULTS_FILENAME"
    return 0
  fi

  return 1
}

# ---------------------------------------------------------------------------
# Parse a flat YAML file into an associative array
# ---------------------------------------------------------------------------
# Handles: key: value, key: "value", key: 'value'
# Skips: comments, blank lines, copier internal keys (_prefix)
parse_yaml_into() {
  local -n _yaml_map=$1
  local file="$2"
  local line key value

  while IFS= read -r line || [[ -n "$line" ]]; do
    # Skip comments and blank lines
    [[ "$line" =~ ^[[:space:]]*($|#) ]] && continue
    # Skip copier internal keys
    [[ "$line" =~ ^[[:space:]]*_ ]] && continue
    # Parse key: value
    if [[ "$line" =~ ^([a-zA-Z][a-zA-Z0-9_]*)[[:space:]]*:[[:space:]]*(.*) ]]; then
      key="${BASH_REMATCH[1]}"
      value="${BASH_REMATCH[2]}"
      # Strip surrounding quotes first (quoted values may contain #)
      if [[ "$value" =~ ^\"(.*)\"$ ]] || [[ "$value" =~ ^\'(.*)\'$ ]]; then
        value="${BASH_REMATCH[1]}"
      else
        # Trim trailing inline comments (only for unquoted values)
        value="${value%%[[:space:]]#*}"
      fi
      # Trim trailing whitespace
      value="${value%"${value##*[![:space:]]}"}"
      # Skip empty values
      [[ -z "$value" ]] && continue
      _yaml_map["$key"]="$value"
    fi
  done < "$file"
}

# ---------------------------------------------------------------------------
# Alias map: short name → copier variable
# ---------------------------------------------------------------------------
declare -A ALIAS_MAP=(
  [cli]=has_cli
  [core]=has_core_library
  [config]=has_config
  [jsonl]=has_jsonl_logging
  [otel]=has_opentelemetry
  [bench]=has_benchmarks
  [gungraun]=has_gungraun
  [site]=has_site
  [community]=has_community_files
  [claude]=has_claude
  [yamlfmt]=has_yamlfmt
  [yamllint]=has_yamllint
  [editorconfig]=has_editorconfig
  [env]=has_env_files
  [agents_md]=has_agents_md
  [gitattributes]=has_gitattributes
  [github]=has_github
  [security_md]=has_security_md
  [issues]=has_issue_templates
  [prs]=has_pr_templates
  [md]=has_md
  [mcp]=has_mcp_server
  [md_strict]=has_md_strict
  [releases]=has_releases
  [coda]=has_coda
  [roadmap_votes]=has_roadmap_votes
  [inquire]=has_inquire
  [indicatif]=has_indicatif
)

# Sorted alias names for display
SORTED_ALIASES=$(printf '%s\n' "${!ALIAS_MAP[@]}" | sort)

# ---------------------------------------------------------------------------
# Usage
# ---------------------------------------------------------------------------
usage() {
  cat <<'EOF'
Usage: claylo-rs <command> [options] [+feature-flags]

Commands:
  new <dest>       Create a new project (copier copy)
  update [dest]    Update an existing project (copier update)
  usage            Print template capability manifest (for AI agents)

Options:
  --preset <name>      minimal, library, standard, full (default: standard)
  --lint <level>       strict, standard, relaxed (default: from preset)
  --hook <system>      pre-commit, lefthook, none (default: none)
  --owner <name>       GitHub org/username
  --copyright <name>   Copyright holder name
  --desc <text>        Project description
  --vcs-ref <ref>      Template git ref (see: copier copy --help-all)
  --local              Use local template repo instead of GitHub
  --data key=value     Pass arbitrary data to copier (repeatable)
  --data-file <path>   YAML file with default values (copier --data-file)
  --conflict <mode>    rej or inline (default: inline, update only)
  --dry-run            Preview without writing files
  -y, --yes            Accept preset defaults, only prompt for missing values
  --version, -V        Show version
  --help               Show this help

If --data-file is not specified, the script looks for .claylo-rs.defaults.yaml
in the current directory and each parent directory up to /.

Feature flags (prefix with + to enable, - to disable):
  cli, core, config, jsonl, otel, mcp, bench, gungraun, site,
  community, claude, yamlfmt, yamllint, editorconfig, env,
  agents_md, gitattributes, github, security_md, issues, prs,
  md, md_strict, releases, coda, roadmap_votes, inquire, indicatif

Examples:
  claylo-rs new ./my-app --owner myorg --copyright "My Name"
  claylo-rs new ./my-app --preset full +otel-site
  claylo-rs new ./my-app --preset minimal +core+config+bench
  claylo-rs new ./my-app --preset minimal -y
  claylo-rs new ./my-app --data-file ~/my-defaults.yaml
  claylo-rs new ./my-app --vcs-ref v1.0.0
  claylo-rs update ./my-app +otel
  claylo-rs update . -site-community
  claylo-rs new ./my-app --data edition=2021 --data msrv=1.80.0
EOF
}

# ---------------------------------------------------------------------------
# Parse a +feat+feat or -feat-feat string into --data flags
#
# Aliases use underscores (pandoc-style), so +/- are unambiguous delimiters.
# Supports: "+otel+mcp", "-site-community", "+core+config-site"
# ---------------------------------------------------------------------------
parse_features() {
  local input="$1"
  local -n _fmap=$2  # nameref to caller's associative array

  [[ -z "$input" ]] && return 0

  # First character must be + or -
  if [[ "${input:0:1}" != "+" && "${input:0:1}" != "-" ]]; then
    echo "Error: feature string must start with + or -: ${input}" >&2
    exit 1
  fi

  # Insert a newline before each + or - so we can split on them
  local delimited
  delimited=$(printf '%s' "$input" | sed 's/[+-]/\n&/g')

  while IFS= read -r token; do
    [[ -z "$token" ]] && continue
    local prefix="${token:0:1}"
    local name="${token:1}"

    if [[ -z "$name" ]]; then
      echo "Error: empty feature name after '${prefix}'" >&2
      exit 1
    fi

    if [[ -z "${ALIAS_MAP[$name]+x}" ]]; then
      echo "Error: unknown feature '${name}'" >&2
      echo "" >&2
      echo "Valid features:" >&2
      echo "$SORTED_ALIASES" | paste - - - - | column -t >&2
      exit 1
    fi

    local var="${ALIAS_MAP[$name]}"
    if [[ "$prefix" == "+" ]]; then
      _fmap["$var"]=true
    else
      _fmap["$var"]=false
    fi
  done <<< "$delimited"
}

# ---------------------------------------------------------------------------
# Pretty-print command array for readable output
# ---------------------------------------------------------------------------
print_command() {
  local -n arr=$1
  local i=0
  local len=${#arr[@]}
  local prev_was_flag=false

  echo "Running:"
  printf "  %s" "${arr[0]}"  # copier
  printf " %s" "${arr[1]}"   # copy/update
  ((i=2))

  while ((i < len)); do
    local arg="${arr[i]}"
    case "$arg" in
      --*)
        # Start new line for each flag
        printf " \\\\\n    %s" "$arg"
        prev_was_flag=true
        ;;
      *)
        if [[ "$prev_was_flag" == true ]]; then
          # Value following a flag - stay on same line, quote if needed
          if [[ "$arg" == *" "* ]]; then
            printf " '%s'" "$arg"
          else
            printf " %s" "$arg"
          fi
          prev_was_flag=false
        else
          # Positional argument (not following a flag) - new line
          printf " \\\\\n    %s" "$arg"
        fi
        ;;
    esac
    ((i++))
  done
  echo ""
}

# ---------------------------------------------------------------------------
# Check for recommended tools and report any that are missing
# ---------------------------------------------------------------------------
check_recommended_tools() {
  local -a missing=()

  # Tools the generated project will want
  command -v cargo-binstall &>/dev/null || missing+=("cargo-binstall")
  command -v just &>/dev/null || missing+=(just)
  command -v taplo &>/dev/null || missing+=(taplo)
  command -v cargo-nextest &>/dev/null || missing+=("cargo-nextest")
  command -v cargo-deny &>/dev/null || missing+=("cargo-deny")
  command -v cargo-llvm-cov &>/dev/null || missing+=("cargo-llvm-cov")
  command -v cargo-outdated &>/dev/null || missing+=("cargo-outdated")
  command -v cargo-install-update &>/dev/null || missing+=("cargo-install-update")

  if [[ ${#missing[@]} -gt 0 ]]; then
    echo ""
    echo "────────────────────────────────────────────────────────────────────────"
    echo "Note: The following tools are recommended for this project:"
    echo ""
    for tool in "${missing[@]}"; do
      case "$tool" in
        cargo-binstall)
          echo "  • cargo-binstall — binary installer (cargo install cargo-binstall)"
          ;;
        just)
          echo "  • just — task runner (cargo bininstall just)"
          ;;
        taplo)
          echo "  • taplo — TOML formatter (cargo bininstall taplo-cli)"
          ;;
        cargo-nextest)
          echo "  • cargo-nextest — fast test runner (cargo bininstall cargo-nextest)"
          ;;
        cargo-deny)
          echo "  • cargo-deny — license/security checker (cargo bininstall cargo-deny)"
          ;;
        cargo-llvm-cov)
          echo "  • cargo-llvm-cov — code coverage (cargo bininstall cargo-llvm-cov)"
          ;;
        cargo-outdated)
          echo "  • cargo-outdated — dependency freshness (cargo bininstall cargo-outdated)"
          ;;
        cargo-install-update)
          echo "  • cargo-install-update — update installed crates (cargo bininstall cargo-update)"
          ;;
      esac
    done
    echo ""
    echo "Install all with:"
    echo "  cargo install cargo-binstall && \\"
    echo "  cargo binstall just taplo-cli cargo-nextest cargo-deny \\"
    echo "    cargo-llvm-cov cargo-outdated cargo-update"
    echo "────────────────────────────────────────────────────────────────────────"
  fi
}

# ---------------------------------------------------------------------------
# Load preset-specific feature flags into an associative array
#
# Only includes variables that DIFFER between presets (category 4).
# Computed vars (has_xtask, needs_tokio) are left to copier formulas.
# Choice vars (site_deploy, site_package_manager, lint_level) are left
# to copier defaults or user data-file.
# Redundant vars (same across all presets) are left to copier defaults.
# ---------------------------------------------------------------------------
# BEGIN GENERATED: load_preset_flags
load_preset_flags() {
  local preset="$1"
  local -n _pmap=$2

  case "$preset" in
    full)
      _pmap[has_attestations]=true
      _pmap[has_benchmarks]=true
      _pmap[has_cli]=true
      _pmap[has_community_files]=true
      _pmap[has_config]=true
      _pmap[has_core_library]=true
      _pmap[has_editorconfig]=true
      _pmap[has_env_files]=true
      _pmap[has_gungraun]=false
      _pmap[has_jsonl_logging]=true
      _pmap[has_md]=true
      _pmap[has_md_strict]=false
      _pmap[has_opentelemetry]=true
      _pmap[has_releases]=true
      _pmap[has_site]=true
      _pmap[has_yamlfmt]=true
      _pmap[has_yamllint]=true
      ;;
    library)
      _pmap[has_attestations]=false
      _pmap[has_benchmarks]=true
      _pmap[has_cli]=false
      _pmap[has_community_files]=false
      _pmap[has_config]=false
      _pmap[has_core_library]=true
      _pmap[has_editorconfig]=false
      _pmap[has_env_files]=false
      _pmap[has_jsonl_logging]=false
      _pmap[has_md]=true
      _pmap[has_md_strict]=false
      _pmap[has_opentelemetry]=false
      _pmap[has_releases]=true
      _pmap[has_site]=false
      _pmap[has_yamlfmt]=false
      _pmap[has_yamllint]=false
      ;;
    minimal)
      _pmap[has_attestations]=true
      _pmap[has_benchmarks]=false
      _pmap[has_cli]=true
      _pmap[has_community_files]=false
      _pmap[has_config]=false
      _pmap[has_core_library]=false
      _pmap[has_editorconfig]=false
      _pmap[has_env_files]=false
      _pmap[has_jsonl_logging]=false
      _pmap[has_md]=false
      _pmap[has_opentelemetry]=false
      _pmap[has_releases]=false
      _pmap[has_site]=false
      _pmap[has_yamlfmt]=false
      _pmap[has_yamllint]=false
      ;;
    standard)
      _pmap[has_attestations]=true
      _pmap[has_benchmarks]=false
      _pmap[has_cli]=true
      _pmap[has_community_files]=false
      _pmap[has_config]=true
      _pmap[has_core_library]=true
      _pmap[has_editorconfig]=false
      _pmap[has_env_files]=false
      _pmap[has_jsonl_logging]=true
      _pmap[has_md]=true
      _pmap[has_md_strict]=false
      _pmap[has_opentelemetry]=false
      _pmap[has_releases]=true
      _pmap[has_site]=true
      _pmap[has_yamlfmt]=false
      _pmap[has_yamllint]=false
      ;;
  esac
}
# END GENERATED: load_preset_flags

# ---------------------------------------------------------------------------
# Usage — embedded template capability manifest (synced from llms.md)
# ---------------------------------------------------------------------------
# BEGIN GENERATED: llms_content
show_usage() {
  cat <<'LLMS_EOF'
# claylo-rs: Rust CLI Project Template

> A Copier template that generates production-ready Rust CLI workspaces with modular feature selection.

Source: `gh:claylo/claylo-rs`

## What This Template Provides

When an AI agent is helping plan, brainstorm, or implement features in a project generated by claylo-rs, it should understand that the following infrastructure **already exists** and should not be recreated.

## Project Generation

```bash
# Create a new project (non-interactive)
claylo-rs new ./my-tool --preset standard -y

# With feature flags (+ enables, - disables)
claylo-rs new ./my-tool --preset standard +otel+mcp-bench -y

# Supply identity fields for fully unattended generation
claylo-rs new ./my-tool --preset standard --owner myorg --copyright "My Name" -y

# Update an existing project
claylo-rs update
```

The `-y` / `--yes` flag accepts preset defaults without prompting. Without it, copier will prompt for any values not supplied via flags or defaults files.

### Defaults File

If a `.claylo-rs.defaults.yaml` file exists in the current directory or any parent directory up to `/`, it is automatically loaded as default values. This lets teams or individuals pre-fill identity fields (owner, copyright, description) so `-y` works without extra flags:

```yaml
# ~/.claylo-rs.defaults.yaml — personal defaults
owner: myorg
copyright_name: "My Name"
project_description: "A Rust CLI tool"
```

For full option details, run `claylo-rs --help`.

### Presets

Four presets configure coherent defaults:

| Preset | What you get |
|--------|-------------|
| `minimal` | CLI binary only. No config, no logging, no telemetry. |
| `library` | Core library + benchmarks + release automation. No CLI binary or binary distribution. |
| `standard` | CLI + core library + config + JSONL logging + documentation site + release automation |
| `full` | Everything in standard + benchmarks + OpenTelemetry + community files + editor configs + env files |

## Workspace Structure

Generated projects use a Cargo workspace with crates under `crates/`:

```
my-tool/
├── crates/
│   ├── my-tool/              # CLI binary (clap, anyhow)
│   └── my-tool-core/         # Library (thiserror, domain logic)   [+core]
├── xtask/                    # Build automation (completions, man pages)
├── config/                   # Example config files (TOML, YAML)   [+config]
├── site/                     # Astro Starlight documentation site   [+site]
├── npm/                      # NPM binary distribution packages    [+cli +releases]
├── bench-reports/            # Benchmark output storage             [+bench]
├── dist/share/               # Generated completions and man pages
├── .github/                  # CI/CD workflows, actions, templates  [+github]
├── .claude/                  # Agent config, skills, commands       [+claude]
├── scripts/add-crate         # Workspace crate scaffolding tool
├── Cargo.toml                # Workspace manifest
├── deny.toml                 # Security/license policy
├── rust-toolchain.toml       # Pinned toolchain
├── cliff.toml                # git-cliff changelog config           [+releases]
└── .justfile                 # Task runner recipes
```

**Architecture principle: thin CLI, fat core.** The CLI crate handles argument parsing and I/O. Feature logic, types, and dependencies belong in the `-core` library crate. This keeps the core testable without subprocess gymnastics.

## What's Already Built — Don't Reinvent These

### CLI Framework

- **clap** (derive) for argument parsing with subcommands
- Color output control (`--color auto|always|never`)
- `--version`, `--version-only` flags
- `--chdir` for directory change before execution
- Exit codes following standard conventions

### Built-in Subcommands

| Command | Included | What it does |
|---------|----------|-------------|
| `info` | Always | Version, build info, config status. Supports `--json`. |
| `doctor` | When `+config` | Diagnostic output: config paths, XDG dirs, env vars. Supports `--json`. |
| `serve` | When `+mcp` | MCP server over stdio transport. |

### Adding New Subcommands

1. Create `crates/<project>/src/commands/your_cmd.rs`
2. Add variant to `Commands` enum in `crates/<project>/src/lib.rs`
3. Wire it up in `match cli.command` in `main.rs`
4. Add integration tests in `crates/<project>/tests/`

There is a Claude Code skill at `.claude/skills/adding-commands/` that guides this process.

### Configuration System (when `+config`)

- **figment**-based configuration loading
- TOML and YAML format support
- Hierarchical discovery: XDG config dirs → project directory → parent directories
- `ConfigLoader` with builder pattern
- `ConfigError` / `ConfigResult` types via thiserror
- Example config files in `config/` directory

**Do not build a config system.** Use `ConfigLoader::new().with_project_search(&cwd)`.

### Observability (when `+jsonl` or `+otel`)

- **tracing** + **tracing-subscriber** for structured logging
- **tracing-appender** for daily-rotated JSONL file logging
- `RUST_LOG` environment variable support
- `ObservabilityConfig` struct for centralized setup
- OpenTelemetry OTLP export (when `+otel`)
  - Reads `OTEL_EXPORTER_OTLP_ENDPOINT` from environment
  - Merges with config file `otel_endpoint` setting
  - Adds **tokio** async runtime automatically

**Do not add logging infrastructure.** It exists. Use `tracing::info!()` etc.

### Error Handling

- **thiserror** in the `-core` library crate for typed errors
- **anyhow** in the CLI binary for ad-hoc error propagation
- Error types defined in `crates/<project>-core/src/error.rs`

**Do not add `Box<dyn Error>` or invent error types.** Extend the existing `thiserror` enum.

### Interactive CLI (opt-in)

- **inquire** (when `+inquire`) — Text, Select, Confirm prompts
- **indicatif** (when `+indicatif`) — progress bars and spinners

### MCP Server (when `+mcp`)

- Model Context Protocol server scaffold
- stdio transport with tokio async runtime
- Resource discovery and tool invocation handlers
- Logging routed to JSONL files (not stdout — stdout is the MCP transport)

## Task Runner (justfile)

All development tasks have `just` recipes. **Never run raw cargo commands when a recipe exists.**

### Core Recipes (always present)

| Recipe | What it does |
|--------|-------------|
| `just bootstrap` | First-time setup: MSRV check, hook install, build, generate completions/man pages |
| `just check` | Full quality gate: fmt + clippy + deny + test + doc-test |
| `just test` | `cargo nextest run` (NOT `cargo test`) |
| `just clippy` | Lint with pinned toolchain, all targets, all features |
| `just fmt` | `cargo fmt --all` |
| `just fix` | Auto-fix clippy warnings |
| `just deny` | Security and license audit |
| `just cov` | Coverage via `cargo llvm-cov nextest` |
| `just watch` | Watch mode for tests |
| `just watch-clippy` | Watch mode for clippy |

### Dependency Management (always present)

| Recipe | What it does |
|--------|-------------|
| `just outdated` | Check for outdated deps (root only) |
| `just update` | Safe update: respects semver, only touches Cargo.lock |
| `just upgrade` | Upgrade Cargo.toml to latest compatible versions |
| `just upgrade-breaking` | Upgrade to latest incompatible versions |
| `just refresh` | Update + test + clippy |
| `just monthly` | Full maintenance: upgrade + test + clippy + release build |

### Documentation Site (when `+site`)

| Recipe | What it does |
|--------|-------------|
| `just site-install` | Install site dependencies |
| `just site-dev` | Start dev server |
| `just site-build` | Production build |
| `just site-preview` | Preview production build |

### Benchmarks (when `+bench`)

| Recipe | What it does |
|--------|-------------|
| `just bench` | Run all benchmarks via xtask |
| `just bench-divan` | Wall-clock microbenchmarks only |
| `just bench-cli` | CLI benchmarks via hyperfine |
| `just bench-gungraun` | Instruction-count benchmarks (when `+gungraun`) |

### Release Management (when `+releases`)

| Recipe | What it does |
|--------|-------------|
| `just changelog` | Generate CHANGELOG.md via git-cliff |
| `just changelog-preview` | Preview unreleased changes |
| `just bump` | Auto-calculate and apply next semantic version |
| `just release v1.2.3` | Full release with pre-checks, changelog, tag |
| `just release-check` | Pre-release validation (clean tree, tests, clippy, deny, release build) |

### Markdown Linting (when `+md`)

| Recipe | What it does |
|--------|-------------|
| `just mdlint` | Lint markdown (rumdl or markdownlint) |
| `just mdfix` | Auto-fix markdown issues |

### Workspace Scaffolding (always present)

| Recipe | What it does |
|--------|-------------|
| `just add-crate lib my-utils` | Add a library crate |
| `just add-crate bin my-daemon` | Add a binary crate |
| `just add-crate internal my-macros --derive` | Add proc-macro crate |

The `add-crate` script generates `Cargo.toml` with workspace inheritance, conventional dependencies, and runs `cargo check` to verify.

## CI/CD (when `+github`)

### GitHub Actions Workflows

| Workflow | Trigger | What it does |
|----------|---------|-------------|
| `ci.yml` | PR, push to main | lint (fmt + clippy) → test (nextest + doctests) → cargo-deny → MSRV check |
| `lint-pr.yml` | PR title | Validates conventional commit format in PR titles |
| `dependabot-issues.yml` | Dependabot PR | Auto-creates tracking issues for dependency updates |
| `deploy-site.yml` | Push to main | Build and deploy Starlight docs (when `+site`) |
| `benchmarks.yml` | Manual/scheduled | Run benchmarks and store results (when `+bench`) |
| `release.yml` | Push to main | Auto-release via git-cliff (when `+releases`) |
| `cd.yml` | Tag push `v*.*.*` | Cross-platform builds, GitHub Release, optional publishing |

### CD Build Matrix (when `+releases`)

Cross-compilation for 8 targets:

| Platform | Targets |
|----------|---------|
| Linux | x86_64-gnu, x86_64-musl, aarch64-gnu, aarch64-musl |
| macOS | x86_64-apple-darwin, aarch64-apple-darwin |
| Windows | x86_64-pc-windows-msvc, aarch64-pc-windows-msvc |

### Optional Publishing

Publishing targets are controlled by **GitHub repo variables**, not template flags — they can be toggled after project generation without re-running the template:

| Variable | What it enables |
|----------|----------------|
| `CRATES_IO_ENABLED` | Publish to crates.io |
| `HOMEBREW_ENABLED` | Update Homebrew formula |
| `NPM_ENABLED` | Publish to npm (platform-specific binary packages) |
| `DEB_ENABLED` | Build .deb packages |
| `RPM_ENABLED` | Build .rpm packages |
| `SBOM_ENABLED` | Generate CycloneDX SBOM |
| `GPG_SIGNING_ENABLED` | Sign release artifacts |

## Code Quality Defaults

| Setting | Value |
|---------|-------|
| Rust edition | 2024 (also supports 2021) |
| MSRV | 1.89.0 |
| `unsafe_code` | `deny` |
| Clippy (`--lint strict`) | `all` + `nursery` = warn |
| Clippy (`--lint standard`) | `all` = warn |
| cargo-deny | License allowlist + security advisory checking |
| cargo-auditable | Embedded dependency info in release binaries |

## Documentation Site (when `+site`)

- **Astro** + **Starlight** theme
- Content in `site/src/content/docs/` (MDX)
- Guides and CLI reference pages pre-generated
- LLM-friendly endpoints: `/llms.txt` and `/llms-full.txt`
- Deployment: GitHub Pages (default), Cloudflare Pages (via GH Actions or git integration)
- Package manager: npm (default), pnpm, bun, or yarn

## Claude Code Integration (when `+claude`)

Generates `.claude/settings.json` with pre-configured permissions for common development tools (cargo, git, just, gh) and security-conscious deny rules (no force-push, no rm -rf, no reading secrets).

## Feature Flags

All flags toggle with `+flag` / `-flag` on the `claylo-rs` command line.

### Structure & Runtime

| Flag | Description |
|------|-------------|
| `+cli` | CLI binary crate (default: on) |
| `+core` | Separate `-core` library crate |
| `+config` | Configuration file support (figment, TOML/YAML) |
| `+jsonl` | Structured JSONL file logging (daily-rotated) |
| `+otel` | OpenTelemetry trace export (adds tokio) |
| `+mcp` | MCP server as `serve` subcommand (adds tokio) |
| `+inquire` | Interactive prompts (Text, Select, Confirm) |
| `+indicatif` | Progress bars and spinners |

### Performance

| Flag | Description |
|------|-------------|
| `+bench` | divan (wall-clock) + hyperfine (CLI) benchmarks |
| `+gungraun` | Instruction-count benchmarks (requires Valgrind) |

### Documentation & Community

| Flag | Description |
|------|-------------|
| `+site` | Astro Starlight documentation site |
| `+community` | CODE_OF_CONDUCT.md + CONTRIBUTING.md |
| `+security_md` | SECURITY.md |
| `+agents_md` | AGENTS.md for AI agents |
| `+md` | Markdown linting (lenient/SEMBR-friendly) |
| `+md_strict` | Stricter markdown rules |

### GitHub & Releases

| Flag | Description |
|------|-------------|
| `+github` | .github/ directory with CI/CD workflows |
| `+issues` | Bug report + feature request issue templates |
| `+prs` | PR templates (bugfix, docs, feature) |
| `+releases` | git-cliff changelogs + release workflow (+ binary distribution when `+cli`) |
| `+attestations` | Sigstore artifact attestations |
| `+coda` | gh-coda repo settings automation |
| `+roadmap_votes` | Roadmap voting workflow |

### Dotfiles & Tooling

| Flag | Description |
|------|-------------|
| `+yamlfmt` | YAML formatter config |
| `+yamllint` | YAML linter config |
| `+editorconfig` | Cross-editor settings |
| `+env` | .env + .env.rust + .envrc |
| `+gitattributes` | Line ending normalization |

### Git Hooks

Set with `--hook <system>`: `none` (default), `pre-commit`, `lefthook`.

### Claude Code

| Flag | Description |
|------|-------------|
| `+claude` | .claude/settings.json with agent permissions |

### Lint Level

Set with `--lint <level>`: `strict` (all + nursery), `standard` (all), `relaxed` (Rust defaults).

## Dependency Stack

These are already wired up. Do not add alternatives.

| Purpose | Crate(s) | Where |
|---------|----------|-------|
| CLI parsing | `clap` (derive) + `clap_complete` | binary |
| Man pages | `clap_mangen` | xtask |
| Errors (lib) | `thiserror` | core |
| Errors (bin) | `anyhow` | binary |
| Logging | `tracing` + `tracing-subscriber` + `tracing-appender` | binary |
| Serialization | `serde` + `serde_json` | core |
| Config | `figment` + `toml` + `serde_yml` | core |
| Colors | `owo-colors` | binary |
| Paths | `camino` | core |
| Directories | `directories` | core |
| Prompts | `inquire` | binary (`+inquire`) |
| Progress | `indicatif` | binary (`+indicatif`) |
| OTEL | `opentelemetry` + `opentelemetry-otlp` + `tracing-opentelemetry` | binary (`+otel`) |
| MCP | `rmcp` | binary (`+mcp`) |
| Async | `tokio` | binary (`+otel` or `+mcp`) |
| Benchmarks | `divan` | core (`+bench`) |
| Testing | `assert_cmd` + `predicates` + `tempfile` + `insta` | dev-deps |

## Post-Generation Setup

After `claylo-rs new`, run `just bootstrap`. It handles MSRV validation, git hooks, formatting, building, shell completions, man pages, site deps, and repo settings — everything needed to go from template output to working project.

## Architecture Decision Records

Generated projects include `docs/decisions/` for MADR-format ADRs. The `capturing-decisions` Claude Code skill provides a template.

## Updating Projects

```bash
claylo-rs update                  # update from latest template (inline conflict markers by default)
claylo-rs update --conflict rej   # use .rej sidecar files instead
```
LLMS_EOF
}
# END GENERATED: llms_content

# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------
main() {
  if [[ $# -eq 0 ]]; then
    usage
    exit 1
  fi

  local command="$1"
  shift

  case "$command" in
    --help | -h | help)
      usage
      exit 0
      ;;
    --version | -V)
      echo "claylo-rs ${VERSION}"
      exit 0
      ;;
    new | update) ;;
    usage)
      show_usage
      exit 0
      ;;
    *)
      echo "Error: unknown command '${command}'" >&2
      echo "" >&2
      usage
      exit 1
      ;;
  esac

  # Check for copier (only needed for new/update, not help)
  if ! command -v copier &>/dev/null; then
    echo "Error: copier not found." >&2
    echo "Install: uv tool install copier" >&2
    exit 1
  fi

  # Parse remaining args
  local dest=""
  local preset="standard"
  local preset_set=false
  local lint=""
  local hook=""
  local owner=""
  local copyright=""
  local desc=""
  local vcs_ref=""
  local use_local=false
  local conflict="inline"
  local dry_run=false
  local use_defaults=false
  local data_file=""
  local key
  local feature_strings=()
  declare -A feature_map=()
  declare -A extra_data_map=()

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --preset)
        [[ $# -lt 2 ]] && { echo "Error: --preset requires a value" >&2; exit 1; }
        preset="$2"
        preset_set=true
        case "$preset" in
          minimal | library | standard | full) ;;
          *) echo "Error: invalid preset '${preset}' (minimal, library, standard, full)" >&2; exit 1 ;;
        esac
        shift 2
        ;;
      --lint)
        [[ $# -lt 2 ]] && { echo "Error: --lint requires a value" >&2; exit 1; }
        lint="$2"
        case "$lint" in
          strict | standard | relaxed) ;;
          *) echo "Error: invalid lint level '${lint}' (strict, standard, relaxed)" >&2; exit 1 ;;
        esac
        shift 2
        ;;
      --hook)
        [[ $# -lt 2 ]] && { echo "Error: --hook requires a value" >&2; exit 1; }
        hook="$2"
        case "$hook" in
          pre-commit | lefthook | none) ;;
          *) echo "Error: invalid hook system '${hook}' (pre-commit, lefthook, none)" >&2; exit 1 ;;
        esac
        shift 2
        ;;
      --owner)
        [[ $# -lt 2 ]] && { echo "Error: --owner requires a value" >&2; exit 1; }
        owner="$2"
        shift 2
        ;;
      --copyright)
        [[ $# -lt 2 ]] && { echo "Error: --copyright requires a value" >&2; exit 1; }
        copyright="$2"
        shift 2
        ;;
      --desc)
        [[ $# -lt 2 ]] && { echo "Error: --desc requires a value" >&2; exit 1; }
        desc="$2"
        shift 2
        ;;
      --vcs-ref)
        [[ $# -lt 2 ]] && { echo "Error: --vcs-ref requires a git ref" >&2; exit 1; }
        vcs_ref="$2"
        shift 2
        ;;
      --local)
        use_local=true
        shift
        ;;
      --data)
        [[ $# -lt 2 ]] && { echo "Error: --data requires a key=value" >&2; exit 1; }
        if [[ "$2" =~ ^([^=]+)=(.*)$ ]]; then
          extra_data_map["${BASH_REMATCH[1]}"]="${BASH_REMATCH[2]}"
        else
          echo "Error: --data value must be key=value format: $2" >&2
          exit 1
        fi
        shift 2
        ;;
      --data-file)
        [[ $# -lt 2 ]] && { echo "Error: --data-file requires a path" >&2; exit 1; }
        if [[ ! -f "$2" ]]; then
          echo "Error: data file not found: $2" >&2
          exit 1
        fi
        data_file="$2"
        shift 2
        ;;
      --conflict)
        [[ $# -lt 2 ]] && { echo "Error: --conflict requires a value" >&2; exit 1; }
        conflict="$2"
        case "$conflict" in
          rej | inline) ;;
          *) echo "Error: invalid conflict mode '${conflict}' (rej, inline)" >&2; exit 1 ;;
        esac
        shift 2
        ;;
      --dry-run)
        dry_run=true
        shift
        ;;
      -y | --yes)
        use_defaults=true
        shift
        ;;
      --help | -h)
        usage
        exit 0
        ;;
      [+-]*)
        feature_strings+=("$1")
        shift
        ;;
      *)
        if [[ -z "$dest" ]]; then
          dest="$1"
        else
          echo "Error: unexpected argument '${1}'" >&2
          exit 1
        fi
        shift
        ;;
    esac
  done

  # Parse all feature strings into associative array
  for fs in "${feature_strings[@]}"; do
    parse_features "$fs" feature_map
  done

  # Auto-discover defaults file if not explicitly provided
  if [[ -z "$data_file" ]]; then
    local discovered
    if discovered="$(find_defaults_file)"; then
      data_file="$discovered"
      echo "Using defaults from: $data_file"
    fi
  fi

  # Determine template source
  local template_src="$DEFAULT_TEMPLATE"
  if [[ "$use_local" == true ]]; then
    if [[ -f "${LOCAL_TEMPLATE}/copier.yaml" ]]; then
      template_src="$LOCAL_TEMPLATE"
    else
      echo "Error: --local specified but no copier.yaml found at ${LOCAL_TEMPLATE}" >&2
      exit 1
    fi
  fi

  # ---------------------------------------------------------------------------
  # Build the copier command
  # ---------------------------------------------------------------------------
  # Precedence (highest to lowest):
  #   1. CLI flags (--lint, --hook, +features, --data key=value)
  #   2. Data-file (~/.claylo-rs.defaults.yaml or --data-file path)
  #   3. Preset flags (category-4 vars that differ between presets)
  #   4. copier.yaml defaults (handled by copier itself)
  #
  # Layers 1-3 are merged here. No --data-file is sent to copier.
  # Computed vars (has_xtask, needs_tokio) are never emitted — copier
  # evaluates their formulas from copier.yaml.
  # ---------------------------------------------------------------------------
  local -a cmd=()

  if [[ "$command" == "new" ]]; then
    [[ -z "$dest" ]] && { echo "Error: destination path required" >&2; echo "Usage: claylo-rs new <dest>" >&2; exit 1; }

    local project_name
    project_name="$(basename "$dest")"

    # --- Merge layers into associative array ---
    declare -A merged=()

    # Layer 1 (lowest): preset flags
    load_preset_flags "$preset" merged

    # Layer 2: data-file overwrites preset
    if [[ -n "$data_file" ]]; then
      parse_yaml_into merged "$data_file"
    fi

    # Layer 3: CLI named flags overwrite data-file
    [[ -n "$owner" ]] && merged[owner]="$owner"
    [[ -n "$copyright" ]] && merged[copyright_name]="$copyright"
    [[ -n "$desc" ]] && merged[project_description]="$desc"
    [[ -n "$lint" ]] && merged[lint_level]="$lint"
    [[ -n "$hook" ]] && merged[hook_system]="$hook"

    # Layer 4: +/- feature flags overwrite everything so far
    for key in "${!feature_map[@]}"; do
      merged["$key"]="${feature_map[$key]}"
    done

    # Layer 5 (highest): --data key=value overrides all
    for key in "${!extra_data_map[@]}"; do
      merged["$key"]="${extra_data_map[$key]}"
    done

    # Always set project_name; only override preset if explicitly requested
    merged[project_name]="$project_name"
    if [[ "$preset_set" == true ]]; then
      merged[preset]="$preset"
    else
      merged[preset]="${merged[preset]:-$preset}"
    fi

    # --- Build copier command ---
    cmd=(copier copy --prereleases)
    [[ "$use_defaults" == true ]] && cmd+=(--defaults)
    [[ "$dry_run" == true ]] && cmd+=(--pretend)
    [[ -n "$vcs_ref" ]] && cmd+=(--vcs-ref "$vcs_ref")

    # Emit merged data (sorted for deterministic output)
    while IFS= read -r key; do
      cmd+=(--data "${key}=${merged[$key]}")
    done < <(printf '%s\n' "${!merged[@]}" | sort)

    cmd+=("$template_src" "$dest")

  elif [[ "$command" == "update" ]]; then
    [[ -z "$dest" ]] && dest="."

    # --- Merge layers into associative array ---
    declare -A merged=()

    # Layer 1 (lowest): preset flags — only if explicitly requested
    if [[ "$preset_set" == true ]]; then
      load_preset_flags "$preset" merged
      merged[preset]="$preset"
    fi

    # Layer 2: data-file overwrites preset
    if [[ -n "$data_file" ]]; then
      parse_yaml_into merged "$data_file"
    fi

    # Layer 3: CLI named flags
    [[ -n "$owner" ]] && merged[owner]="$owner"
    [[ -n "$copyright" ]] && merged[copyright_name]="$copyright"
    [[ -n "$desc" ]] && merged[project_description]="$desc"
    [[ -n "$lint" ]] && merged[lint_level]="$lint"
    [[ -n "$hook" ]] && merged[hook_system]="$hook"

    # Layer 4: +/- feature flags
    for key in "${!feature_map[@]}"; do
      merged["$key"]="${feature_map[$key]}"
    done

    # Layer 5 (highest): --data key=value
    for key in "${!extra_data_map[@]}"; do
      merged["$key"]="${extra_data_map[$key]}"
    done

    # --- Build copier command ---
    cmd=(copier update --prereleases)
    [[ "$use_defaults" == true ]] && cmd+=(--defaults)
    [[ "$dry_run" == true ]] && cmd+=(--pretend)
    [[ -n "$vcs_ref" ]] && cmd+=(--vcs-ref "$vcs_ref")
    cmd+=(--conflict "$conflict")
    cmd+=(--answers-file .repo.yml)

    # Emit merged data (sorted for deterministic output)
    while IFS= read -r key; do
      cmd+=(--data "${key}=${merged[$key]}")
    done < <(printf '%s\n' "${!merged[@]}" | sort)

    cmd+=("$dest")
  fi

  # Show what we're running
  print_command cmd
  echo ""

  # Run copier (not exec, so we can check tools afterward)
  "${cmd[@]}"
  local exit_code=$?

  # If successful and not a dry run, check for recommended tools
  if [[ $exit_code -eq 0 && "$dry_run" == false ]]; then
    check_recommended_tools
  fi

  exit $exit_code
}

main "$@"